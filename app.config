<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!-- ============================================================
       SKClaw Configuration
       All runtime settings are managed here.
       ============================================================ -->

  <appSettings>

    <!-- ── Application ─────────────────────────────────────────── -->
    <add key="App:Name" value="SKClaw" />
    <add key="App:Version" value="1.0.0" />
    <add key="App:Environment" value="Development" />
    <add key="App:LogLevel" value="Information" />
    <!-- Debug | Information | Warning | Error | Critical | None -->

    <!-- ── Default LLM Provider ─────────────────────────────────
         Options: openai | gemini | anthropic | ollama | openai-compatible
    ──────────────────────────────────────────────────────────────-->
    <add key="LLM:DefaultProvider" value="openai" />
    <add key="LLM:DefaultModel" value="gpt-4o" />
    <add key="LLM:DefaultEmbeddingModel" value="text-embedding-3-small" />
    <add key="LLM:MaxTokens" value="4096" />
    <add key="LLM:Temperature" value="0.7" />
    <add key="LLM:TopP" value="1.0" />
    <add key="LLM:RequestTimeoutSeconds" value="120" />

    <!-- ── OpenAI ────────────────────────────────────────────────-->
    <add key="LLM:OpenAI:ApiKey" value="sk-YOUR_OPENAI_KEY" />
    <add key="LLM:OpenAI:OrgId" value="" />
    <add key="LLM:OpenAI:Endpoint" value="https://api.openai.com/v1" />
    <add key="LLM:OpenAI:ChatModel" value="gpt-4o" />
    <add key="LLM:OpenAI:EmbeddingModel" value="text-embedding-3-small" />
    <add key="LLM:OpenAI:ImageModel" value="dall-e-3" />

    <!-- ── Google Gemini ─────────────────────────────────────────-->
    <add key="LLM:Gemini:ApiKey" value="YOUR_GEMINI_API_KEY" />
    <add key="LLM:Gemini:ChatModel" value="gemini-1.5-pro" />
    <add key="LLM:Gemini:EmbeddingModel" value="text-embedding-004" />
    <add key="LLM:Gemini:Endpoint" value="https://generativelanguage.googleapis.com" />

    <!-- ── Anthropic Claude ──────────────────────────────────────-->
    <add key="LLM:Anthropic:ApiKey" value="sk-ant-YOUR_ANTHROPIC_KEY" />
    <add key="LLM:Anthropic:ChatModel" value="claude-sonnet-4-20250514" />
    <add key="LLM:Anthropic:Endpoint" value="https://api.anthropic.com" />
    <add key="LLM:Anthropic:Version" value="2023-06-01" />

    <!-- ── Ollama (local) ────────────────────────────────────────-->
    <add key="LLM:Ollama:Endpoint" value="http://localhost:11434" />
    <add key="LLM:Ollama:ChatModel" value="llama3.2" />
    <add key="LLM:Ollama:EmbeddingModel" value="nomic-embed-text" />

    <!-- ── OpenAI-Compatible (LM Studio, Together, Groq, etc.) ──-->
    <add key="LLM:OpenAICompatible:Endpoint" value="http://localhost:1234/v1" />
    <add key="LLM:OpenAICompatible:ApiKey" value="lm-studio" />
    <add key="LLM:OpenAICompatible:ChatModel" value="local-model" />
    <add key="LLM:OpenAICompatible:EmbeddingModel" value="local-embedding" />

    <!-- ── Memory / Vector Store ─────────────────────────────────
         Options: inmemory | sqlite | qdrant | chroma
    ──────────────────────────────────────────────────────────────-->
    <add key="Memory:Provider" value="sqlite" />
    <add key="Memory:CollectionName" value="skclaw_memory" />
    <add key="Memory:RelevanceThreshold" value="0.7" />
    <add key="Memory:MaxResults" value="10" />

    <!-- SQLite memory -->
    <add key="Memory:Sqlite:ConnectionString" value="Data Source=skclaw_memory.db" />

    <!-- Qdrant memory -->
    <add key="Memory:Qdrant:Endpoint" value="http://localhost:6333" />
    <add key="Memory:Qdrant:ApiKey" value="" />
    <add key="Memory:Qdrant:VectorSize" value="1536" />

    <!-- Chroma memory -->
    <add key="Memory:Chroma:Endpoint" value="http://localhost:8000" />

    <!-- ── MCP Server ─────────────────────────────────────────────-->
    <add key="MCP:Enabled" value="true" />
    <add key="MCP:ServerName" value="SKClaw MCP Server" />
    <add key="MCP:Version" value="1.0.0" />
    <add key="MCP:Transport" value="sse" />
    <!-- sse | stdio -->
    <add key="MCP:SsePath" value="/mcp/sse" />
    <add key="MCP:MessagePath" value="/mcp/message" />
    <!-- External MCP servers to connect to (comma-separated JSON configs) -->
    <add key="MCP:ExternalServers" value="" />

    <!-- ── Web Server ─────────────────────────────────────────────-->
    <add key="Web:Enabled" value="true" />
    <add key="Web:Host" value="0.0.0.0" />
    <add key="Web:Port" value="5000" />
    <add key="Web:UseHttps" value="false" />
    <add key="Web:CertPath" value="" />
    <add key="Web:CertPassword" value="" />
    <add key="Web:AllowedOrigins" value="*" />

    <!-- Admin Panel -->
    <add key="Web:Admin:Enabled" value="true" />
    <add key="Web:Admin:Path" value="/admin" />
    <add key="Web:Admin:Username" value="admin" />
    <add key="Web:Admin:Password" value="changeme123" />
    <add key="Web:Admin:JwtSecret" value="your-super-secret-jwt-key-change-this-in-production" />
    <add key="Web:Admin:JwtExpiryHours" value="24" />

    <!-- Web Chat -->
    <add key="Web:Chat:Enabled" value="true" />
    <add key="Web:Chat:Path" value="/chat" />
    <add key="Web:Chat:Title" value="SKClaw Chat" />
    <add key="Web:Chat:WelcomeMessage" value="Halo! Saya SKClaw, asisten AI Anda. Ada yang bisa saya bantu?" />
    <add key="Web:Chat:AllowFileUploads" value="true" />
    <add key="Web:Chat:MaxFileSizeMb" value="10" />

    <!-- Integration API -->
    <add key="Web:Api:Enabled" value="true" />
    <add key="Web:Api:Path" value="/api" />
    <add key="Web:Api:RequireAuth" value="true" />
    <add key="Web:Api:RateLimitPerMinute" value="60" />
    <add key="Web:Api:ApiKeys" value="" />
    <!-- comma-separated list of valid API keys -->

    <!-- ── Channels ───────────────────────────────────────────────-->
    <!-- Telegram -->
    <add key="Channels:Telegram:Enabled" value="false" />
    <add key="Channels:Telegram:BotToken" value="YOUR_TELEGRAM_BOT_TOKEN" />
    <add key="Channels:Telegram:AllowedUsers" value="" />
    <!-- empty = allow all -->
    <add key="Channels:Telegram:WebhookUrl" value="" />
    <!-- empty = polling -->

    <!-- Discord -->
    <add key="Channels:Discord:Enabled" value="false" />
    <add key="Channels:Discord:BotToken" value="YOUR_DISCORD_BOT_TOKEN" />
    <add key="Channels:Discord:GuildId" value="" />
    <add key="Channels:Discord:ChannelIds" value="" />
    <!-- comma-separated -->
    <add key="Channels:Discord:CommandPrefix" value="!" />

    <!-- Slack -->
    <add key="Channels:Slack:Enabled" value="false" />
    <add key="Channels:Slack:BotToken" value="xoxb-YOUR_SLACK_BOT_TOKEN" />
    <add key="Channels:Slack:AppToken" value="xapp-YOUR_SLACK_APP_TOKEN" />
    <add key="Channels:Slack:SigningSecret" value="YOUR_SLACK_SIGNING_SECRET" />

    <!-- WhatsApp (via Twilio) -->
    <add key="Channels:WhatsApp:Enabled" value="false" />
    <add key="Channels:WhatsApp:AccountSid" value="YOUR_TWILIO_ACCOUNT_SID" />
    <add key="Channels:WhatsApp:AuthToken" value="YOUR_TWILIO_AUTH_TOKEN" />
    <add key="Channels:WhatsApp:FromNumber" value="whatsapp:+14155238886" />

    <!-- LINE -->
    <add key="Channels:Line:Enabled" value="false" />
    <add key="Channels:Line:ChannelAccessToken" value="YOUR_LINE_CHANNEL_ACCESS_TOKEN" />
    <add key="Channels:Line:ChannelSecret" value="YOUR_LINE_CHANNEL_SECRET" />

    <!-- ── Plugins / Skills ───────────────────────────────────────-->
    <add key="Plugins:AutoLoad" value="true" />
    <add key="Plugins:Directory" value="./plugins" />
    <add key="Plugins:EnabledSkills" value="TimeSkill,MathSkill,HttpSkill,FileSkill,CodeSkill,SearchSkill,SummarizeSkill,TranslateSkill,ImageSkill,EmailSkill" />

    <!-- Web Search (for SearchSkill) -->
    <add key="Plugins:Search:Provider" value="bing" />
    <!-- bing | google | duckduckgo -->
    <add key="Plugins:Search:BingApiKey" value="YOUR_BING_API_KEY" />
    <add key="Plugins:Search:GoogleApiKey" value="YOUR_GOOGLE_API_KEY" />
    <add key="Plugins:Search:GoogleCseId" value="YOUR_GOOGLE_CSE_ID" />
    <add key="Plugins:Search:MaxResults" value="5" />

    <!-- Code Execution (for CodeSkill) -->
    <add key="Plugins:Code:Enabled" value="false" />
    <add key="Plugins:Code:AllowedLanguages" value="python,javascript,csharp" />
    <add key="Plugins:Code:TimeoutSeconds" value="30" />
    <add key="Plugins:Code:MaxOutputBytes" value="10240" />

    <!-- Email (for EmailSkill via SMTP) -->
    <add key="Plugins:Email:SmtpHost" value="smtp.gmail.com" />
    <add key="Plugins:Email:SmtpPort" value="587" />
    <add key="Plugins:Email:SmtpUser" value="" />
    <add key="Plugins:Email:SmtpPassword" value="" />
    <add key="Plugins:Email:UseSsl" value="true" />

    <!-- ── Agent Settings ────────────────────────────────────────-->
    <add key="Agent:Name" value="SKClaw" />
    <add key="Agent:Description" value="A powerful AI assistant powered by Semantic Kernel" />
    <add key="Agent:SystemPrompt" value="You are SKClaw, a helpful AI assistant. You have access to various tools and skills to help users effectively. Always be helpful, accurate, and concise." />
    <add key="Agent:MaxIterations" value="10" />
    <add key="Agent:EnablePlanner" value="true" />
    <add key="Agent:PlannerType" value="sequential" />
    <!-- sequential | handlebars | stepwise -->
    <add key="Agent:EnableMemory" value="true" />
    <add key="Agent:MemoryWindowSize" value="20" />
    <!-- number of conversation turns to keep -->
    <add key="Agent:StreamResponse" value="true" />

    <!-- ── Storage ───────────────────────────────────────────────-->
    <add key="Storage:Provider" value="sqlite" />
    <!-- sqlite | postgres | sqlserver -->
    <add key="Storage:Sqlite:Path" value="skclaw.db" />
    <add key="Storage:Postgres:ConnectionString" value="" />
    <add key="Storage:SqlServer:ConnectionString" value="" />

    <!-- ── Telemetry ─────────────────────────────────────────────-->
    <add key="Telemetry:Enabled" value="false" />
    <add key="Telemetry:OtelEndpoint" value="http://localhost:4317" />
    <add key="Telemetry:ServiceName" value="SKClaw" />

  </appSettings>

</configuration>
