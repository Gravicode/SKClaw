FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS base
WORKDIR /app
EXPOSE 5001

FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY ["src/SKClaw.Core/SKClaw.Core.csproj", "src/SKClaw.Core/"]
COPY ["src/SKClaw.MCP/SKClaw.MCP.csproj", "src/SKClaw.MCP/"]

RUN dotnet restore "src/SKClaw.MCP/SKClaw.MCP.csproj"

COPY . .

RUN dotnet build "src/SKClaw.MCP/SKClaw.MCP.csproj" -c Release -o /app/build

FROM build AS publish
RUN dotnet publish "src/SKClaw.MCP/SKClaw.MCP.csproj" -c Release -o /app/publish \
    --no-restore

FROM base AS final
WORKDIR /app
COPY --from=publish /app/publish .

RUN mkdir -p /root/.skclaw/workspace

ENTRYPOINT ["dotnet", "SKClaw.MCP.dll"]
